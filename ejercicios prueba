 29)  Un censador recopila ciertos datos aplicando encuestas para el último Censo Nacional de Población y Vivienda. Desea obtener de todas las personas que alcance a encuestar en un día, que porcentaje tiene estudios de primaria, secundaria, carrera técnica, estudios profesionales y estudios de posgrado

primaria = 0
secundaria = 0
tecnica = 0
profesional = 0
posgrado = 0


n = int(input("Ingrese la cantidad de personas encuestadas (0 para salir): "))


if n == 0:
    print("Programa finalizado.")
else:
    while n < 0:
        print("Error: no se permiten números negativos")
        n = int(input("Ingrese la cantidad de personas (0 para salir): "))

    persona = 1

    while persona <= n:
        print("\nPersona", persona)
        print("Nivel de estudios:")
        print("1. Primaria")
        print("2. Secundaria")
        print("3. Carrera técnica")
        print("4. Profesional")
        print("5. Posgrado")
        
        opcion = int(input("Seleccione una opción (1-5): "))
        
        while opcion < 1 or opcion > 5:
            print("Error: opción inválida")
            opcion = int(input("Seleccione una opción válida (1-5): "))
        
        if opcion == 1:
            primaria =primaria+ 1
        elif opcion == 2:
            secundaria =secundaria+ 1
        elif opcion == 3:
            tecnica = tecnica+ 1
        elif opcion == 4:
            profesional = profesional+ 1
        elif opcion == 5:
            posgrado =posgrado+ 1

        persona += 1

    print("\n--- RESULTADOS ---")
    print("Primaria: ", (primaria / n) * 100, "%")
    print("Secundaria: ", (secundaria / n) * 100, "%")
    print("Carrera técnica: ", (tecnica / n) * 100, "%")
    print("Profesional: ", (profesional / n) * 100, "%")
    print("Posgrado: ", (posgrado / n) * 100, "%")

