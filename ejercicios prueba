        if opcion == 1:
            primaria =primaria+ 1
        elif opcion == 2:
            secundaria =secundaria+ 1
        elif opcion == 3:
            tecnica = tecnica+ 1
        elif opcion == 4:
            profesional = profesional+ 1
        elif opcion == 5:
            posgrado =posgrado+ 1

